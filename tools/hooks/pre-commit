#!/bin/sh
# Pre-commit hook: gate on generated-doc drift, then bump the 3rd version number.

pwsh -NoProfile -Command '
  $result = Invoke-DelphiIncVer -File "source/radAuthenticator.Info.Pas" -IncVerTarget "Text" -IncVerStyle "WinVer" -IncVerPart "patch"  -IncVerPattern "Version\s*=\s*\x27(\d+\.\d+\.\d+)\x27"
  if (-not $result.Success) {
    Write-Error "IncVer failed: $($result.Message)"
    exit 1
  }
  Write-Host "Version: $($result.OldVersion) -> $($result.NewVersion)"
'

# Stage the version file so it's included in the commit.
git add source/radAuthenticator.Info.pas
